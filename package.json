{
  "name": "codecharter",
  "version": "0.1.13",
  "description": "Turn a codebase into a deterministic 2D map with geohash addresses and agent activity hooks.",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "keywords": [
    "code-map",
    "codemap",
    "codebase",
    "geohash",
    "agent",
    "codex",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "codecharter": "dist/bin/codemap.mjs",
    "codemap": "dist/bin/codemap.mjs"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm build:public && tsc -p tsconfig.build.json && chmod +x dist/bin/codemap.mjs && mkdir -p dist/public && cp public/index.html public/style.css public/app.js public/deep-links.js public/render-model.js dist/public/ && cp package.json dist/package.json",
    "build:public": "tsc -p tsconfig.public.json",
    "codecharter": "node ./bin/codemap.mts",
    "codemap": "node ./bin/codemap.mts",
    "setup": "node ./bin/codemap.mts init --yes",
    "dev": "node ./bin/codemap.mts dev",
    "serve": "node ./bin/codemap.mts serve",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "tsx test-support/run-tests.mts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
