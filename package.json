{
  "name": "codecharter",
  "version": "0.1.13",
  "description": "Turn a codebase into a deterministic 2D map with geohash addresses and agent activity hooks.",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "keywords": [
    "code-map",
    "codemap",
    "codebase",
    "geohash",
    "agent",
    "codex",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "src",
    "public",
    "README.md"
  ],
  "bin": {
    "codecharter": "bin/codemap.mjs",
    "codemap": "bin/codemap.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "codecharter": "node ./bin/codemap.mjs",
    "codemap": "node ./bin/codemap.mjs",
    "setup": "node ./bin/codemap.mjs init --yes",
    "dev": "node ./bin/codemap.mjs dev",
    "serve": "node ./bin/codemap.mjs serve",
    "typecheck": "tsc --noEmit",
    "test": "tsx test-support/run-tests.mts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
