{
  "name": "codecharter",
  "version": "0.2.1",
  "description": "Deterministic geohash-addressed code map with an agent-activity overlay. Modernized monorepo: @codecharter/core (codemap engine + hardened localhost server + CLI) and @codecharter/viewer (canvas SPA).",
  "type": "module",
  "bin": {
    "codecharter": "dist/bin/codemap.mjs",
    "codemap": "dist/bin/codemap.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "core",
    "viewer"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "node --test test/*.test.mjs && npm run test --workspaces --if-present",
    "codecharter": "tsx core/bin/codemap.mts",
    "generate": "tsx core/bin/codemap.mts generate",
    "serve": "tsx core/bin/codemap.mts serve"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "tsx": "^4.22.3"
  }
}
