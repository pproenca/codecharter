{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2024", "DOM"],
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "public",
    "rootDir": "public-src",
    "sourceMap": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "useUnknownInCatchVariables": true,
    "noUncheckedIndexedAccess": true,
    "strict": false
  },
  "include": ["public-src/**/*.ts"]
}
